# Ambiente dos remotes: development | staging | production
# Se omitido: development no `npm start`, production no `npm run build`
# MFE_ENV=development

# Opcional: sobrescreve a URL base de um remote (sem /remoteEntry.js)
# MFE_REMOTE_HEADER_URL=https://cdn.example.com/header
# MFE_REMOTE_CARDS_URL=https://cdn.example.com/cards
# MFE_REMOTE_FOOTER_URL=https://cdn.example.com/footer
